<!DOCTYPE html>
<html lang="vi">
<%- include('../partials/head', { title: 'Lịch sử dịch' }) %>
<body>
<div class="app-shell">
  <%- include('../partials/sidebar', { active: 'history', admin: admin }) %>

  <main class="main">
    <div class="page-header">
      <div>
        <div class="page-eyebrow">Quản trị hệ thống</div>
        <h1>Lịch sử dịch thuật</h1>
      </div>
    </div>

    <div class="panel">
      <form method="GET" action="/history" class="form-row" style="align-items: flex-end;">
        <div class="form-group">
          <label for="from">Từ ngày</label>
          <input type="date" id="from" name="from" value="<%= from %>" />
        </div>
        <div class="form-group">
          <label for="to">Đến ngày</label>
          <input type="date" id="to" name="to" value="<%= to %>" />
        </div>
        <button type="submit" class="btn btn-ghost">Lọc</button>
      </form>
    </div>

    <div class="panel">
      <% if (records.length === 0) { %>
        <div class="empty-state">Chưa có bản ghi lịch sử nào</div>
      <% } else { %>
        <table>
          <thead>
            <tr><th>Người dùng</th><th>Ngôn ngữ</th><th>Văn bản gốc</th><th>Bản dịch</th><th>Loại</th><th>Thời gian</th><th></th></tr>
          </thead>
          <tbody>
            <% records.forEach(r => { %>
              <tr>
                <td><%= r.user?.fullName || '—' %><br/><span class="mono" style="font-size:11px;color:var(--text-muted);"><%= r.user?.email %></span></td>
                <td class="mono"><%= r.sourceLanguage %> → <%= r.targetLanguage %></td>
                <td><%= r.sourceText.length > 60 ? r.sourceText.slice(0,60)+'…' : r.sourceText %></td>
                <td><%= r.translatedText.length > 60 ? r.translatedText.slice(0,60)+'…' : r.translatedText %></td>
                <td><%= r.type %></td>
                <td class="mono"><%= new Date(r.createdAt).toLocaleString('vi-VN') %></td>
                <td>
                  <form class="inline-form" method="POST" action="/history/<%= r._id %>/delete" onsubmit="return confirm('Xóa bản ghi này?');">
                    <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="pagination">
          <% for (let p = 1; p <= totalPages; p++) { %>
            <a href="/history?page=<%= p %>&from=<%= from %>&to=<%= to %>" class="<%= p == page ? 'active' : '' %>"><%= p %></a>
          <% } %>
        </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
